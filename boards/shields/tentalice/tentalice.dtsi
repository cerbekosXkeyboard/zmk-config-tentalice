#include <dt-bindings/zmk/matrix_transform.h>
#include "tentalice-layouts.dtsi"
#include <dt-bindings/led/led.h>

/ {
  chosen {
    zmk,kscan = &kscan0;
    transform = <&default_transform>;
    zmk,physical-layout = &tentalice_default_layout;
    zmk,underglow = &led_strip;
  };

  kscan0: kscan {
    compatible = "zmk,kscan-gpio-charlieplex";
    wakeup-source;
    interrupt-gpios = <&gpio0 9 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN) >;
   };

  default_transform: matrix_transform {
    compatible = "zmk,matrix-transform";
    rows = <7>;
    columns = <7>;
    map = <
      RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6)   RC(1,0) RC(1,2) RC(1,3) RC(1,4) RC(1,5) RC(1,6)
      RC(2,0) RC(2,1) RC(2,3) RC(2,4) RC(2,5) RC(2,6)   RC(3,0) RC(3,1) RC(3,2) RC(3,4) RC(3,5) RC(3,6) 
      RC(4,0) RC(4,1) RC(4,2) RC(4,3) RC(4,5) RC(4,6)   RC(5,0) RC(5,1) RC(5,2) RC(5,3) RC(5,4) RC(5,6) 
      RC(6,0)                 RC(6,1) RC(6,2)                   RC(6,3) RC(6,4)                 RC(6,5) 
    >;
  };
};

&uicr {
        nfct-pins-as-gpios;
};

&pinctrl {
    spi3_default: spi3_default {
        group1 {
            psels = <NRF_PSEL(SPIM_MOSI, 0, 10)>;
        };
    };

    spi3_sleep: spi3_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_MOSI, 0, 10)>;
            low-power-enable;
        };
    };
};

&spi3 {
    compatible = "nordic,nrf-spim";
    status = "okay";

    pinctrl-0 = <&spi3_default>;
    pinctrl-1 = <&spi3_sleep>;
    pinctrl-names = "default", "sleep";

    led_strip: ws2812@0 {
        compatible = "worldsemi,ws2812-spi";

        reg = <0>;
        spi-max-frequency = <4000000>;
        chain-length = <4>; 
        spi-one-frame = <0x70>;
        spi-zero-frame = <0x40>;
        color-mapping = <LED_COLOR_ID_GREEN
                         LED_COLOR_ID_RED
                         LED_COLOR_ID_BLUE>;
    };
};