        };

        /* 日本語キーボード用マクロ定義 */

        jp_dquote: jp_dquote {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            label = "JP_DQUOTE";
            bindings = <&kp AT>;
        };

        jp_amp: jp_amp {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            label = "JP_AMP";
            bindings = <&kp CARET>;
        };

        jp_quote: jp_quote {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            label = "JP_QUOTE";
            bindings = <&kp AMPERSAND>;
        };

        jp_equal: jp_equal {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            label = "JP_EQUAL";
            bindings = <&kp UNDER>;
        };

        jp_caret: jp_caret {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            label = "JP_CARET";
            bindings = <&kp EQUAL>;
        };

        jp_yen: jp_yen {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            label = "JP_YEN";
            bindings = <&kp 0x89>;
        };

        jp_plus: jp_plus {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            label = "JP_PLUS";
            bindings = <&kp COLON>;
        };

        jp_tilde: jp_tilde {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            label = "JP_TILDE";
            bindings = <&kp PLUS>;
        };

        jp_pipe: jp_pipe {
